pipeline {
    agent any

    environment {
        DOCKER_IMAGE   = "meditracker"
        CONTAINER_NAME = "meditracker-simple"
        APP_PORT       = "5001"
        MONGO_URI      = credentials('mongo-uri')
        SECRET_KEY     = credentials('secret-key')
        METRICS_FILE   = "C:\\devops-mhealth\\metrics-simple.csv"
    }

    stages {

        stage('Checkout') {
            steps {
                echo '📥 Récupération du code...'
                checkout scm
            }
        }

        stage('Build Docker Image') {
            steps {
                echo '🐳 Build de image Docker...'
                bat "docker build -t %DOCKER_IMAGE%:simple-%BUILD_NUMBER% ."
                bat "docker tag %DOCKER_IMAGE%:simple-%BUILD_NUMBER% %DOCKER_IMAGE%:simple-latest"
            }
        }

        stage('Deploy Rolling') {
            steps {
                echo '🚀 Déploiement Rolling...'
                bat "docker stop %CONTAINER_NAME% 2>nul & exit /b 0"
                bat "docker rm   %CONTAINER_NAME% 2>nul & exit /b 0"
                bat """
                    docker run -d ^
                      --name %CONTAINER_NAME% ^
                      --network devops-network ^
                      -p %APP_PORT%:5000 ^
                      -e SECRET_KEY=%SECRET_KEY% ^
                      -e MONGO_URI=%MONGO_URI% ^
                      -e MONGO_DBNAME=meditracker ^
                      --restart unless-stopped ^
                      %DOCKER_IMAGE%:simple-%BUILD_NUMBER%
                """
            }
        }

        stage('Health Check') {
            steps {
                echo '💓 Health Check...'
                bat "ping -n 21 127.0.0.1 > nul"
                script {
                    def status = bat(
                        script: "curl -s -o nul -w %%{http_code} http://localhost:%APP_PORT%/",
                        returnStdout: true
                    ).trim()
                    echo "HTTP Status: ${status}"
                }
            }
        }

        stage('Collect Metrics') {
            steps {
                echo '📊 Enregistrement des métriques...'
                bat "if not exist C:\\devops-mhealth mkdir C:\\devops-mhealth"
                bat """
                    echo %BUILD_NUMBER%,SIMPLE,ROLLING,%DATE%,%TIME%,SUCCESS >> %METRICS_FILE%
                """
            }
        }
    }

    post {
        success {
            echo '✅ Pipeline Simple RÉUSSI !'
            bat "echo %BUILD_NUMBER%,SUCCESS >> %METRICS_FILE%"
        }
        failure {
            echo '❌ Pipeline Simple ÉCHOUÉ !'
            bat "echo %BUILD_NUMBER%,FAILURE >> %METRICS_FILE%"
        }
        always {
            bat "docker image prune -f 2>nul & exit /b 0"
        }
    }
}