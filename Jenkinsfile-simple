pipeline {
    agent any

    environment {
        DOCKER_IMAGE = "meditracker"
        CONTAINER_NAME = "meditracker-simple"
        APP_PORT = "5001"
        MONGO_URI = credentials('mongo-uri')
        SECRET_KEY = credentials('secret-key')
    }

    stages {

        stage('Checkout') {
            steps {
                echo '📥 Récupération du code...'
                checkout scm
            }
        }

        stage('Build Docker Image') {
            steps {
                echo "🐳 Build de l'image Docker..."
                bat "docker build -t %DOCKER_IMAGE%:simple-%BUILD_NUMBER% ."
                bat "docker tag %DOCKER_IMAGE%:simple-%BUILD_NUMBER% %DOCKER_IMAGE%:simple-latest"
            }
        }

        stage('Deploy') {
            steps {
                echo '🚀 Déploiement direct (Rolling)...'
                script {
                    // Stop ancien container sans erreur si inexistant
                    bat """
                        docker stop %CONTAINER_NAME% 2>nul
                        exit /b 0
                    """
                    bat """
                        docker rm %CONTAINER_NAME% 2>nul
                        exit /b 0
                    """
                    // Lance le nouveau container
                    bat """
                        docker run -d ^
                          --name %CONTAINER_NAME% ^
                          --network devops-network ^
                          -p %APP_PORT%:5000 ^
                          -e SECRET_KEY=%SECRET_KEY% ^
                          -e MONGO_URI=%MONGO_URI% ^
                          -e MONGO_DBNAME=meditracker ^
                          --restart unless-stopped ^
                          %DOCKER_IMAGE%:simple-%BUILD_NUMBER%
                    """
                }
            }
        }

        stage('Health Check') {
            
            steps {
                echo '💓 Vérification santé...'
                // Attente de 20 secondes (compatible Jenkins Windows)
                bat "ping -n 21 127.0.0.1 > nul"
                script {
                    def result = bat(
                        script: "curl -s -o nul -w %%{http_code} http://localhost:%APP_PORT%/",
                        returnStdout: true
                    ).trim()
                    echo "HTTP Status: ${result}"
                }
            }
        }
        
    }

    post {
        success {
            echo '✅ Pipeline Simple réussi !'
            bat "echo %BUILD_NUMBER%,SUCCESS,%DATE%,%TIME% >> C:\\devops-mhealth\\metrics-simple.csv"
        }
        failure {
            echo '❌ Pipeline Simple échoué !'
            bat "echo %BUILD_NUMBER%,FAILURE,%DATE%,%TIME% >> C:\\devops-mhealth\\metrics-simple.csv"
        }
        always {
            bat "docker image prune -f 2>nul & exit /b 0"
        }
    }
}