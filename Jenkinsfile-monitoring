pipeline {
    agent any

    environment {
        DOCKER_IMAGE = "meditracker"
        MONGO_URI = credentials('mongo-uri')
        SECRET_KEY = credentials('secret-key')
        SONAR_TOKEN = credentials('sonarqube-token')
        CONTAINER_NAME = "meditracker-monitored"
        APP_PORT = "5004"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
                echo "🔖 Build #${BUILD_NUMBER} — Branche: ${GIT_BRANCH}"
            }
        }

        stage('Code Quality') {
            parallel {
                stage('SonarQube') {
                    steps {
                        withSonarQubeEnv('SonarQube') {
                            bat """
                                sonar-scanner ^
                                  -Dsonar.projectKey=meditracker ^
                                  -Dsonar.sources=. ^
                                  -Dsonar.login=%SONAR_TOKEN% ^
                                  -Dsonar.exclusions=**/static/**,**/templates/**,**/wireframes/**
                            """
                        }
                    }
                }
                stage('Lint') {
                    steps {
                        bat "pip install flake8 || echo ok"
                        bat "python -m flake8 app.py --max-line-length=120 || echo Lint done"
                    }
                }
            }
        }

        stage('Build') {
            steps {
                bat "docker build -t %DOCKER_IMAGE%:mon-%BUILD_NUMBER% ."
            }
        }

        stage('Canary Deploy (10%)') {
            steps {
                echo '🐤 Déploiement Canary — 10% du trafic...'
                bat "docker stop meditracker-canary || echo ok"
                bat "docker rm meditracker-canary || echo ok"
                bat """
                    docker run -d ^
                      --name meditracker-canary ^
                      --network devops-network ^
                      -p 5005:5000 ^
                      -e SECRET_KEY=%SECRET_KEY% ^
                      -e MONGO_URI=%MONGO_URI% ^
                      -e MONGO_DBNAME=meditracker ^
                      %DOCKER_IMAGE%:mon-%BUILD_NUMBER%
                """
                bat "timeout /t 30 /nobreak"
                bat "curl -f http://localhost:5005/ || error Canary failed"
                echo '✅ Canary OK — Passage à 100%'
            }
        }

        stage('Full Deploy + Monitoring') {
            steps {
                echo '🚀 Déploiement complet avec monitoring...'
                bat "docker stop %CONTAINER_NAME% || echo ok"
                bat "docker rm %CONTAINER_NAME% || echo ok"
                bat """
                    docker run -d ^
                      --name %CONTAINER_NAME% ^
                      --network devops-network ^
                      -p %APP_PORT%:5000 ^
                      -e SECRET_KEY=%SECRET_KEY% ^
                      -e MONGO_URI=%MONGO_URI% ^
                      -e MONGO_DBNAME=meditracker ^
                      --label prometheus.scrape=true ^
                      --restart unless-stopped ^
                      %DOCKER_IMAGE%:mon-%BUILD_NUMBER%
                """
                bat "docker stop meditracker-canary || echo ok"
                bat "docker rm meditracker-canary || echo ok"
            }
        }

        stage('Validate + Record Metrics') {
            steps {
                bat "timeout /t 20 /nobreak"
                bat "curl -f http://localhost:%APP_PORT%/ || echo check failed"
                bat "docker inspect --format={{.State.Health.Status}} %CONTAINER_NAME% || echo ok"
                echo '📊 Métriques enregistrées dans Prometheus'
            }
        }
    }

    post {
        success {
            bat "echo %BUILD_NUMBER%,SUCCESS,%DATE%,%TIME%,WITH_MONITORING >> C:\\devops-mhealth\\metrics-monitoring.csv"
        }
        failure {
            bat "echo %BUILD_NUMBER%,FAILURE,%DATE%,%TIME%,WITH_MONITORING >> C:\\devops-mhealth\\metrics-monitoring.csv"
        }
    }
}